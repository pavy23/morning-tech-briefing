# ─── 로컬 테스트용 환경변수 ───
# 실제 배포는 GitHub Secrets에 등록 (README 참고)

# Gemini API 키 (필수) — https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=AIzaSy-xxxxx

# Resend API 키 (필수) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# 수신 이메일 (선택, 기본값 코드에 내장)
TO_EMAIL=pavy2004@gmail.com

# 발신 이메일 (선택)
# 도메인 인증 전: onboarding@resend.dev 만 사용 가능
# 도메인 인증 후: noreply@yourdomain.com 형태로 변경 가능
FROM_EMAIL=Morning Tech Briefing <onboarding@resend.dev>

# 모델 (선택, 기본값: gemini-2.5-flash)
# 더 빠르고 저렴: gemini-2.5-flash-lite (무료 등급 한도 더 넉넉)
# 최신 고성능: gemini-3.5-flash
MODEL=gemini-2.5-flash
